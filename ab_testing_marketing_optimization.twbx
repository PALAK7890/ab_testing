    <worksheet name='Sheet 17'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Recommended Budget Allocation</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='ab_test_dashboard_ready' name='federated.1xzxzp50wovu3w1fzemxj0erbc8a' />
          </datasources>
          <datasource-dependencies datasource='federated.1xzxzp50wovu3w1fzemxj0erbc8a'>
            <column caption='Roi1' datatype='real' name='[Calculation_6221718442508295]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([total_cost]) = 0 THEN 0&#10;ELSE SUM([profit]) / SUM([total_cost])&#10;END' />
            </column>
            <column caption='roi adjusted' datatype='real' name='[Calculation_6221718456774664]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_6221718442508295] - WINDOW_MIN([Calculation_6221718442508295]) + 0.01'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='allocation' datatype='real' name='[Calculation_6221718456913929]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_6221718456774664] / WINDOW_SUM([Calculation_6221718456774664])'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Reccomended Budget' datatype='real' name='[Calculation_6221718456991754]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_6221718456913929] * 50000'>
                <table-calc ordering-type='Rows' />
              </calculation>
