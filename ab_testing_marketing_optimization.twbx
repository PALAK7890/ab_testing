      <aliases enabled='yes' />
      <column caption='Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_6221718371688448]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([converted])' />
      </column>
      <column caption='Ad Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_6221718371786753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [test_group] = &quot;ad&quot; THEN [converted] END)' />
      </column>
      <column caption='PSA Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_6221718371844098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [test_group] = &quot;psa&quot; THEN [converted] END)' />
      </column>
      <column caption='Absolute Lift' datatype='real' default-format='p0.00%' name='[Calculation_6221718371905539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718371786753] - [Calculation_6221718371844098]' />
      </column>
      <column caption='Relative Lift' datatype='real' default-format='p0.00%' name='[Calculation_6221718371946500]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718371905539] / [Calculation_6221718371844098]' />
      </column>
      <column caption='Total Revenue ' datatype='integer' name='[Calculation_6221718412959750]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue])' />
      </column>
      <column caption='Roi1' datatype='real' name='[Calculation_6221718442508295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([total_cost]) = 0 THEN 0&#10;ELSE SUM([profit]) / SUM([total_cost])&#10;END' />
      </column>
      <column caption='roi adjusted' datatype='real' name='[Calculation_6221718456774664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718442508295] - WINDOW_MIN([Calculation_6221718442508295]) + 0.01'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='allocation' datatype='real' name='[Calculation_6221718456913929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718456774664] / WINDOW_SUM([Calculation_6221718456774664])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Reccomended Budget' datatype='real' name='[Calculation_6221718456991754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718456913929] * 50000'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Equal Budget' datatype='real' name='[Calculation_6221718485766155]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='50000 / COUNTD([ad_type])' />
      </column>
      <column caption='ROI_Adjusted_FIXED' datatype='real' name='[Calculation_6221718486913036]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='[Calculation_6221718518382605] - { FIXED : MIN([Calculation_6221718518382605]) } + 0.01' />
      </column>
      <column caption='roi fixed' datatype='real' name='[Calculation_6221718518382605]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [ad_type] : SUM([profit]) / SUM([total_cost]) }' />
      </column>
      <column caption='Allocation %' datatype='real' name='[Calculation_6221718518640654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6221718486913036] / { FIXED : SUM([Calculation_6221718486913036]) }' />
      </column>
      <column caption='Best Channel' datatype='string' name='[Calculation_6221718519336975]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6221718518382605] = { FIXED : MAX([Calculation_6221718518382605]) }&#10;THEN [ad_type]&#10;END' />
      </column>
      <column caption='Worst Channel' datatype='string' name='[Calculation_6221718519566352]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6221718518382605] = &#10;{ FIXED : MIN(IF [ad_type] != &quot;PSA&quot; THEN [Calculation_6221718518382605] END) }&#10;THEN [ad_type]&#10;END' />
      </column>
      <column caption='AVG Roi' datatype='real' name='[Calculation_6221718519660561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([total_cost])' />
      </column>
      <column caption='Total Budget' datatype='integer' name='[Calculation_6221718519877650]' role='measure' type='quantitative'>
