    <worksheet name='Sheet 11'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>ROI by Ad Type (Ranked)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='ab_test_dashboard_ready' name='federated.1xzxzp50wovu3w1fzemxj0erbc8a' />
          </datasources>
          <datasource-dependencies datasource='federated.1xzxzp50wovu3w1fzemxj0erbc8a'>
            <column caption='Roi1' datatype='real' name='[Calculation_6221718442508295]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([total_cost]) = 0 THEN 0&#10;ELSE SUM([profit]) / SUM([total_cost])&#10;END' />
            </column>
            <column caption='Ad Type' datatype='string' name='[ad_type]' role='dimension' type='nominal' />
            <column-instance column='[ad_type]' derivation='None' name='[none:ad_type:nk]' pivot='key' type='nominal' />
            <column caption='Profit' datatype='real' name='[profit]' role='measure' type='quantitative' />
            <column caption='Total Cost' datatype='real' name='[total_cost]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_6221718442508295]' derivation='User' name='[usr:Calculation_6221718442508295:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1xzxzp50wovu3w1fzemxj0erbc8a].[Action (Ad Type)]'>
            <groupfilter function='level-members' level='[ad_type]' user:ui-action-filter='[Action12_DBA8AC7B247D4F8BADC76E0C7E8A5A22]' user:ui-enumeration='all' user:ui-marker='enumerate' />
